          "patch": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>南京邮电大学</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        body {\n            width: 100vw;\n            height: 100vh;\n            overflow: hidden;\n            background: linear-gradient(45deg, #0047ab, #6a5acd, #00bfff);\n            background-size: 400% 400%;\n            animation: bgFlow 15s ease infinite;\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;\n        }\n        @keyframes bgFlow {\n            0% { background-position: 0% 50%; }\n            50% { background-position: 100% 50%; }\n            100% { background-position: 0% 50%; }\n        }\n        .container {\n            width: 100%;\n            height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            position: relative;\n            z-index: 10;\n        }\n        .title {\n            font-size: clamp(3rem, 12vw, 10rem);\n            font-weight: 800;\n            background: linear-gradient(135deg, #ffffff 0%, #a0c4ff 50%, #bdb2ff 100%);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-shadow: 0 0 30px rgba(160, 196, 255, 0.5);\n            animation: breath 3s ease-in-out infinite, fadeIn 2s ease-out forwards;\n            opacity: 0;\n            cursor: default;\n            transition: all 0.3s ease;\n            user-select: none;\n        }\n        @keyframes breath {\n            0%, 100% { transform: scale(1); filter: brightness(1); }\n            50% { transform: scale(1.02); filter: brightness(1.1); }\n        }\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .title:hover {\n            transform: scale(1.05);\n            text-shadow: 0 0 50px rgba(160, 196, 255, 0.8);\n            filter: brightness(1.2);\n        }\n        #particleCanvas {\n            position: fixed;\n            top: 0;\n            left: 0;\n            z-index: 1;\n            opacity: 0.3;\n        }\n    </style>\n</head>\n<body>\n    <canvas id=\"particleCanvas\"></canvas>\n    <div class=\"container\">\n        <h1 class=\"title\">南京邮电大学</h1>\n    </div>\n    <script>\n        const canvas = document.getElementById('particleCanvas');\n        const ctx = canvas.getContext('2d');\n        let particles = [];\n        let animationId;\n        let isLowPerformance = false;\n\n        let lastTime = performance.now();\n        let frameCount = 0;\n        function checkPerformance() {\n            frameCount++;\n            const now = performance.now();\n            if (now - lastTime >= 1000) {\n                const fps = frameCount;\n                if (fps < 30) {\n                    isLowPerformance = true;\n                    cancelAnimationFrame(animationId);\n                    canvas.style.display = 'none';\n                }\n                frameCount = 0;\n                lastTime = now;\n            }\n            if (!isLowPerformance) {\n                requestAnimationFrame(checkPerformance);\n            }\n        }\n        checkPerformance();\n\n        function resizeCanvas() {\n            canvas.width = window.innerWidth;\n            canvas.height = window.innerHeight;\n        }\n        resizeCanvas();\n        window.addEventListener('resize', resizeCanvas);\n\n        class Particle {\n            constructor() {\n                this.x = Math.random() * canvas.width;\n                this.y = Math.random() * canvas.height;\n                this.size = Math.random() * 2 + 0.5;\n                this.speedX = Math.random() * 0.5 - 0.25;\n                this.speedY = Math.random() * 0.5 - 0.25;\n            }\n            update() {\n                this.x += this.speedX;\n                this.y += this.speedY;\n                if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;\n                if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;\n            }\n            draw() {\n                ctx.fillStyle = 'rgba(255,255,255,0.6)';\n                ctx.beginPath();\n                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);\n                ctx.fill();\n            }\n        }\n\n        function initParticles() {\n            particles = [];\n            const particleCount = Math.min(Math.floor(window.innerWidth / 10), 80);\n            for (let i = 0; i < particleCount; i++) {\n                particles.push(new Particle());\n            }\n        }\n        initParticles();\n\n        function animate() {\n            if (isLowPerformance) return;\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            particles.forEach(p => {\n                p.update();\n                p.draw();\n            });\n            animationId = requestAnimationFrame(animate);\n        }\n        animate();\n    </script>\n</body>\n</html>",
